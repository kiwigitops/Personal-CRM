{
  "name": "personal-crm-agents",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "schema": "../personal-crm-api/prisma/schema.prisma"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/index.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate --schema ../personal-crm-api/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bullmq": "^5.49.1",
    "date-fns": "^4.1.0",
    "fastify": "^5.2.1",
    "ioredis": "^5.6.1",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.2"
  }
}
