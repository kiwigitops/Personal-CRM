{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Personal CRM",
  "version": "0.1.0",
  "identifier": "local.personal-crm.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Personal CRM",
        "width": 1280,
        "height": 840,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
